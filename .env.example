# Supabase 설정
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 서버 전용 service_role 키 (절대 NEXT_PUBLIC_ 접두사 금지 — 브라우저에 노출되면 안 됨)
# Supabase 대시보드 > Project Settings > API > service_role 에서 복사
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 관리자 인증
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
# 관리자 JWT 서명 시크릿 (고엔트로피 랜덤 문자열, 미설정 시 관리자 인증 비활성)
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# Next.js 설정
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ATS 연동 — 초대 발급 API 키 (서버 전용, 절대 NEXT_PUBLIC_ 접두사 금지)
# 생성법: openssl rand -hex 32
INVITE_API_KEY=your_invite_api_key_here

# ATS 연동 — 완료 웹훅 HMAC-SHA256 서명 시크릿 (서버 전용, 절대 NEXT_PUBLIC_ 접두사 금지)
# 생성법: openssl rand -hex 32
# 미설정 시 웹훅 발송이 차단됩니다(fail-closed).
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here
